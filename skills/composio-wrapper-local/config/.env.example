# Composio Configuration Example
# Copy this to .env and fill in your values

# Required: Get from https://platform.composio.dev/settings
COMPOSIO_API_KEY=your_composio_api_key_here

# Optional: Provider to use (openai, anthropic, etc.)
COMPOSIO_PROVIDER=openai

# Optional: Custom base URL for enterprise users
# COMPOSIO_BASE_URL=https://api.composio.dev

# Optional: Workspace ID (if using workspace-level integration)
# COMPOSIO_WORKSPACE_ID=your_workspace_id
